import numpy as np
from sklearn.feature_extraction.text import TfidfVectorizer
from sklearn.naive_bayes import MultinomialNB
from sklearn.pipeline import make_pipeline

# 1. Define Training Data (Intents and Sample Phrases)
data = [
    # Admissions
    ("How do I join the institute?", "admissions"),
    ("Where is the application form?", "admissions"),
    ("When is the deadline to apply?", "admissions"),
    ("I want to enroll in a course", "admissions"),
    
    # Exams
    ("When are the final exams?", "exams"),
    ("What is the test schedule?", "exams"),
    ("Where is the examination hall?", "exams"),
    ("I need my results from the test", "exams"),
    
    # Timetable
    ("What time is my first class?", "timetable"),
    ("Can I see the weekly schedule?", "timetable"),
    ("Are there classes on Saturday?", "timetable"),
    ("When does the lecture start?", "timetable"),
    
    # Hostel
    ("Is there a place to stay on campus?", "hostel"),
    ("How much is the hostel fee?", "hostel"),
    ("Are there dormitories for students?", "hostel"),
    ("Where is the student accommodation?", "hostel"),
    
    # Scholarships
    ("Are there any financial aid programs?", "scholarships"),
    ("How do I apply for a scholarship?", "scholarships"),
    ("Is there a merit-based discount?", "scholarships"),
    ("Can I get a fee waiver?", "scholarships")
]

# Split data into sentences (X) and labels (y)
X_train, y_train = zip(*data)

# 2. Build the Model Pipeline
# TfidfVectorizer converts text to numbers; MultinomialNB is the "Brain"
model = make_pipeline(TfidfVectorizer(), MultinomialNB())

# 3. Train the Classifier
model.fit(X_train, y_train)

# 4. Define Responses for each Intent
responses = {
    "admissions": "Admissions are open! Visit our portal at /apply to start your journey.",
    "exams": "Exams are scheduled for the last week of every month. Check your student portal.",
    "timetable": "The timetable is updated every Sunday on the institute notice board.",
    "hostel": "Our hostel offers double-sharing rooms with 24/7 Wi-Fi and laundry.",
    "scholarships": "We offer 'Bright Mind' scholarships for students with a GPA above 3.8."
}

def classify_and_respond(user_text):
    # Predict the intent
    intent = model.predict([user_text])[0]
    
    # Check prediction probability (Confidence Score)
    probs = model.predict_proba([user_text])
    max_prob = np.max(probs)
    
    # If confidence is too low (less than 30%), return a fallback
    if max_prob < 0.3:
        return "I'm not quite sure. Are you asking about admissions or exams?"
        
    return f"[Intent: {intent.capitalize()}] -> {responses[intent]}"

# 5. Interactive Chat
print("--- Intent-Based Student Assistant Active ---")
while True:
    user_input = input("\nYou: ")
    if user_input.lower() in ['exit', 'quit']: break
    print(f"Bot: {classify_and_respond(user_input)}")
